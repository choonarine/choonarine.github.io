---
export interface Props {
  type?: 'info' | 'warning' | 'success' | 'error';
  title?: string;
}

const { 
  type = 'info', 
  title = ''
} = Astro.props;

const styles = {
  info: {
    border: 'border-blue-300 dark:border-blue-700',
    bg: 'bg-blue-50 dark:bg-blue-900/20',
    icon: 'text-blue-600 dark:text-blue-400',
    titleColor: 'text-blue-900 dark:text-blue-100'
  },
  warning: {
    border: 'border-amber-300 dark:border-amber-700',
    bg: 'bg-amber-50 dark:bg-amber-900/20',
    icon: 'text-amber-600 dark:text-amber-400',
    titleColor: 'text-amber-900 dark:text-amber-100'
  },
  success: {
    border: 'border-green-300 dark:border-green-700',
    bg: 'bg-green-50 dark:bg-green-900/20',
    icon: 'text-green-600 dark:text-green-400',
    titleColor: 'text-green-900 dark:text-green-100'
  },
  error: {
    border: 'border-red-300 dark:border-red-700',
    bg: 'bg-red-50 dark:bg-red-900/20',
    icon: 'text-red-600 dark:text-red-400',
    titleColor: 'text-red-900 dark:text-red-100'
  }
};

// Icon inner shapes only (no outer <svg>) to avoid nested SVG issues
const icons = {
  // info: circle with small dot and vertical line (Feather-like)
  info:
    '<circle cx="12" cy="12" r="9" stroke-linecap="round" stroke-linejoin="round" />' +
    '<line x1="12" y1="8" x2="12" y2="8" stroke-linecap="round" stroke-linejoin="round" />' +
    '<line x1="12" y1="12" x2="12" y2="16" stroke-linecap="round" stroke-linejoin="round" />',
  // warning: alert triangle with exclamation
  warning:
    '<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" stroke-linecap="round" stroke-linejoin="round" />' +
    '<line x1="12" y1="9" x2="12" y2="13" stroke-linecap="round" stroke-linejoin="round" />' +
    '<line x1="12" y1="17" x2="12.01" y2="17" stroke-linecap="round" stroke-linejoin="round" />',
  // success: check inside a circle
  success:
    '<circle cx="12" cy="12" r="9" stroke-linecap="round" stroke-linejoin="round" />' +
    '<polyline points="9 12 12 15 15 10" stroke-linecap="round" stroke-linejoin="round" />',
  // error: X inside a circle
  error:
    '<circle cx="12" cy="12" r="9" stroke-linecap="round" stroke-linejoin="round" />' +
    '<line x1="15" y1="9" x2="9" y2="15" stroke-linecap="round" stroke-linejoin="round" />' +
    '<line x1="9" y1="9" x2="15" y2="15" stroke-linecap="round" stroke-linejoin="round" />'
};

const style = styles[type];
const icon = icons[type];
---

<div class={`border-l-4 ${style.border} ${style.bg} rounded-r-md p-5 my-5`}>
  {title && (
    <div class="flex flex-row items-center gap-3 mb-2">
      <svg
        class={`w-5 h-5 flex-shrink-0 ${style.icon}`}
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        aria-hidden="true"
        focusable="false"
        set:html={icon}
      />
      <h4 class={`font-semibold text-sm m-0 leading-none ${style.titleColor}`}>{title}</h4>
    </div>
  )}
  <div class={`text-sm leading-relaxed ${!title ? 'flex flex-row items-start gap-3' : 'pl-8'}`}>
    {!title && (
      <svg
        class={`w-5 h-5 flex-shrink-0 mt-0.5 ${style.icon}`}
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        aria-hidden="true"
        focusable="false"
        set:html={icon}
      />
    )}
    <div class={!title ? 'flex-1' : ''}>
      <slot />
    </div>
  </div>
</div>
