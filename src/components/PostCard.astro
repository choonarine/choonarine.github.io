---
import type { PostCardProps } from '../types';

interface Props extends PostCardProps {}

const { post, showTags = true } = Astro.props;
---

<article class="border-b border-zinc-200 pb-6 last:border-b-0 dark:border-zinc-800">
  <a href={`/posts/${post.slug}`} class="block group">
    <h2 class="text-2xl font-semibold mb-3 group-hover:underline">
      {post.data.title}
    </h2>
    <p class="text-zinc-700 dark:text-zinc-300 mb-3 leading-relaxed">
      {post.data.description}
    </p>
  </a>
  
  <div class="flex flex-col md:flex-row md:flex-wrap md:items-center gap-4">
    {post.data.pubDate && (
      <time datetime={post.data.pubDate.toISOString()} class="text-sm text-zinc-500 dark:text-zinc-400">
        {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    )}
    
    <div class="flex flex-wrap gap-2">
      <a 
        href={`/categories/${post.data.category.toLowerCase().replace(/\s+/g, '-')}`}
        class="inline-flex items-center border border-zinc-300 px-2 py-1 text-sm font-medium no-underline hover:underline dark:border-zinc-700"
      >
        {post.data.category}
      </a>
      
      {showTags && post.data.tags.map(tag => (
        <a 
          href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
          class="inline-flex items-center gap-1 border border-zinc-300 px-2 py-1 text-sm text-zinc-700 no-underline hover:underline dark:border-zinc-700 dark:text-zinc-300"
        >
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/>
          </svg>
          {tag}
        </a>
      ))}
    </div>
  </div>
</article>
