---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => data.draft !== true);

const allCategories = [...new Set(allPosts.map((post) => post.data.category))].sort();
---

<BaseLayout title="All Categories - choonarine" description="Browse posts by category">
  <h1 class="text-4xl font-semibold mb-8">All Categories</h1>
  <div class="grid gap-4 md:grid-cols-2">
    {allCategories.map((category) => {
      const count = allPosts.filter((post) => post.data.category === category).length;
      const slug = category.toLowerCase().replace(/\s+/g, '-');
      return (
        <a
          href={`/categories/${slug}`}
          class="block border-b border-zinc-200 py-4 no-underline hover:underline dark:border-zinc-800"
        >
          <h2 class="text-xl font-semibold mb-2">{category}</h2>
          <p class="text-zinc-500">{count} {count === 1 ? 'post' : 'posts'}</p>
        </a>
      );
    })}
  </div>
</BaseLayout>
