---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const allCategories = [...new Set(allPosts.map((post) => post.data.category))].sort();
---

<BaseLayout title="All Categories - choonarine" description="Browse posts by category">
  <h1 class="text-4xl font-bold mb-8">All Categories</h1>
  <div class="grid gap-4 md:grid-cols-2">
    {allCategories.map((category) => {
      const count = allPosts.filter((post) => post.data.category === category).length;
      const slug = category.toLowerCase().replace(/\s+/g, '-');
      return (
        <a
          href={`/categories/${slug}`}
          class="p-6 border border-gray-200 dark:border-gray-800 hover:border-blue-500 rounded-lg transition-colors"
        >
          <h2 class="text-xl font-semibold mb-2">{category}</h2>
          <p class="text-gray-500">{count} {count === 1 ? 'post' : 'posts'}</p>
        </a>
      );
    })}
  </div>
</BaseLayout>
