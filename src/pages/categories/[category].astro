---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  const allCategories = [...new Set(allPosts.map((post) => post.data.category))];

  return allCategories.map((category) => {
    const slug = category.toLowerCase().replace(/\s+/g, '-');
    const filteredPosts = allPosts
      .filter((post) => post.data.category === category)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: { category: slug },
      props: { category, posts: filteredPosts },
    };
  });
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`Category: ${category} - choonarine`} description={`Posts in ${category} category`}>
  <h1 class="text-4xl font-semibold mb-2">{category}</h1>
  <p class="text-zinc-600 dark:text-zinc-400 mb-8">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
  
  <div class="space-y-6">
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </div>
</BaseLayout>
