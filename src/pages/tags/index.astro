---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

import { SITE_TITLE } from '../../consts';

const allPosts = await getCollection('posts', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout title={`All Tags - ${SITE_TITLE}`} description="Browse posts by tag">
  <h1 class="text-4xl font-semibold mb-8">All Tags</h1>
  <div class="flex flex-wrap gap-4">
    {allTags.map((tag) => {
      const count = allPosts.filter((post) => post.data.tags.includes(tag)).length;
      const slug = tag.toLowerCase().replace(/\s+/g, '-');
      return (
        <a
          href={`/tags/${slug}`}
          class="border border-zinc-300 px-3 py-1 no-underline hover:underline dark:border-zinc-700"
        >
          #{tag} <span class="text-zinc-500">({count})</span>
        </a>
      );
    })}
  </div>
</BaseLayout>
