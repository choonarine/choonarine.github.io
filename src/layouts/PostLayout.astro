---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import Giscus from '../components/Giscus.astro';
import { TableOfContents } from '../components/TableOfContents';
import CodeBlock from '../components/interactive/CodeBlock';
// @ts-ignore - reading-time doesn't have types
import readingTime from 'reading-time';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const stats = readingTime(post.body);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <TableOfContents headings={headings} client:load />
  <article>
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-4">{post.data.title}</h1>
      <div class="flex items-center gap-3 text-gray-600 dark:text-gray-400 text-sm mb-6">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>·</span>
        <span>{stats.text}</span>
        {post.data.updatedDate && (
          <>
            <span>·</span>
            <span>Updated: {post.data.updatedDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </>
        )}
      </div>
      <div class="flex flex-wrap gap-2">
        <a href={`/categories/${post.data.category.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 hover:bg-blue-200 dark:hover:bg-blue-800 rounded-full text-sm font-semibold transition-colors">
          {post.data.category}
        </a>
        {post.data.tags.map((tag) => (
          <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center gap-1 px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-full text-sm transition-colors">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/>
            </svg>
            {tag}
          </a>
        ))}
      </div>
    </header>
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <Content components={{ pre: CodeBlock }} />
    </div>
  </article>
  <div class="mt-16">
    <Giscus />
  </div>
</BaseLayout>
