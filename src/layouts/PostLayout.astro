---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import Giscus from '../components/Giscus.astro';
import CodeBlock from '../components/interactive/CodeBlock';
// @ts-ignore - reading-time doesn't have types
import readingTime from 'reading-time';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const stats = readingTime(post.body);
const tocItems = headings.filter((heading) => heading.depth === 2);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    <header class="mb-8">
      <h1 class="mb-4 text-4xl font-semibold">{post.data.title}</h1>
      <div class="mb-6 flex items-center gap-3 text-sm text-zinc-600 dark:text-zinc-400">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>/</span>
        <span>{stats.text}</span>
        {post.data.updatedDate && (
          <>
            <span>/</span>
            <span>Updated: {post.data.updatedDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </>
        )}
      </div>
      <div class="flex flex-wrap gap-2">
        <a href={`/categories/${post.data.category.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center border border-zinc-300 px-2 py-1 text-sm font-medium no-underline hover:underline dark:border-zinc-700">
          {post.data.category}
        </a>
        {post.data.tags.map((tag) => (
          <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center gap-1 border border-zinc-300 px-2 py-1 text-sm text-zinc-700 no-underline hover:underline dark:border-zinc-700 dark:text-zinc-300">
            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/>
            </svg>
            {tag}
          </a>
        ))}
      </div>
    </header>
    {tocItems.length > 0 && (
      <section class="mb-10 w-[95%] rounded-lg border border-zinc-200 p-2 mx-auto dark:border-zinc-800">
        <div>
          {tocItems.map((heading, index) => (
            <a
              href={`#${heading.slug}`}
              class:list={[
                'block rounded-md px-4 py-3 text-sm no-underline hover:bg-zinc-100 hover:underline dark:hover:bg-zinc-900',
                index > 0 && 'border-t border-zinc-200 dark:border-zinc-800',
              ]}
            >
              {heading.text}
            </a>
          ))}
        </div>
      </section>
    )}
    <div class="prose prose-lg max-w-none dark:prose-invert">
      <Content components={{ pre: CodeBlock }} />
    </div>
  </article>
  <div class="mt-16">
    <Giscus />
  </div>
</BaseLayout>
